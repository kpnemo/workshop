{
  "name": "new-workshop",
  "private": true,
  "scripts": {
    "start": "pnpm pm2 start ecosystem.config.cjs && pnpm logs",
    "stop": "pnpm pm2 stop ecosystem.config.cjs",
    "restart": "pnpm pm2 restart ecosystem.config.cjs",
    "logs": "pnpm pm2 logs --lines 50",
    "status": "pnpm pm2 list"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "pm2": "^6.0.14"
  }
}
