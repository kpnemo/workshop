{
  "name": "new-workshop",
  "private": true,
  "scripts": {
    "start": "concurrently --names \"be,fe\" --prefix-colors \"blue,green\" --kill-others-on-fail \"pnpm --filter @new-workshop/agent-service dev\" \"pnpm --filter @new-workshop/web-client dev\"",
    "stop": "echo 'Press Ctrl-C in the terminal running `pnpm start` to stop both services.'"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
